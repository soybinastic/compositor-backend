    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data.session_id) pm.collectionVariables.set('session_id', data.session_id);",
                  "  if (data.invite_url) {",
                  "    try {",
                  "      const url = new URL(data.invite_url);",
                  "      const token = url.searchParams.get('token') || url.pathname.split('/').pop();",
                  "      if (token) pm.collectionVariables.set('invite_token', token);",
                  "    } catch (e) {}",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"host_display_name\": \"Host\",\n  \"layout\": \"CONTAIN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", ""]
            },
            "description": "Create a studio session. Returns invite URL and mediasoup WS URL (201).\n\n`layout` optional enum (default CONTAIN):\nCONTAIN, COVER, THUMBNAIL, GRID, SIDE_BY_SIDE, HALFSCREEN, SPOTLIGHT, CINEMA, PICTURE_IN_PICTURE, OVERLAY, FULLSCREEN\n\nOn success, saves `session_id` (and best-effort `invite_token`) to collection variables."
          },
          "response": []
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{session_id}}/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", ""]
            },
            "description": "Fetch session detail by UUID."
          },
          "response": []
        },
        {
          "name": "End Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{session_id}}/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", ""]
            },
            "description": "End a session and return the updated session payload."
          },
          "response": []
        },
        {
          "name": "Update Layout",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"layout\": \"GRID\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{session_id}}/layout/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "layout", ""]
            },
            "description": "Change session layout. Returns 409 if the session has ended.\n\n`layout` required: CONTAIN, COVER, THUMBNAIL, GRID, SIDE_BY_SIDE, HALFSCREEN, SPOTLIGHT, CINEMA, PICTURE_IN_PICTURE, OVERLAY, FULLSCREEN"
          },
          "response": []
        },
        {
          "name": "Validate Invite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invite_token\": \"{{invite_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{session_id}}/validate-invite/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "validate-invite", ""]
            },
            "description": "Validate invite token. Returns room + mediasoup WS info. 403 if invalid, 409 if session ended."
          },
          "response": []
        },
        {
          "name": "Ingest Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{session_id}}/ingest/",
