# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Mediasoup SFU (media plane)
MEDIASOUP_API_URL=http://localhost:4443
MEDIASOUP_ORIGIN=http://localhost:4443
MEDIASOUP_WS_URL=ws://localhost:4443

# Studio frontend (invite links)
STUDIO_FRONTEND_URL=http://localhost:5173

# RTP ingest — IP mediasoup sends PlainTransport RTP to
COMPOSITOR_RTP_HOST=127.0.0.1
COMPOSITOR_RTP_PORT_MIN=50000
COMPOSITOR_RTP_PORT_MAX=50999
PRODUCER_POLL_INTERVAL=2

# Compositor output canvas
CANVAS_WIDTH=1920
CANVAS_HEIGHT=1080
CANVAS_FPS=30

# Recording output directory
RECORDINGS_DIR=./recordings
RECORDING_VIDEO_BITRATE=4000000
RECORDING_AUDIO_BITRATE=128000
RECORDING_EOS_TIMEOUT_SEC=5

# Live streaming
STREAMING_HLS_DIR=./streams/hls
STREAMING_VIDEO_BITRATE=2500000
STREAMING_AUDIO_BITRATE=128000
STREAMING_EOS_TIMEOUT_SEC=5
DEFAULT_RTMP_URL=

# Webhooks (optional — POST lifecycle events to this URL)
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SEC=5

# RTMP reconnection
STREAMING_RTMP_MAX_RECONNECT_ATTEMPTS=5
STREAMING_RTMP_RECONNECT_DELAY_SEC=3

# Graceful shutdown
GRACEFUL_SHUTDOWN_TIMEOUT_SEC=30
